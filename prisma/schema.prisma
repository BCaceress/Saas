// ============================================================
// NoHub Market — Schema único (row-level multi-tenant)
// Um schema físico, um PrismaClient. Isolamento por `tenantId`.
//
// DUAS CAMADAS DE ISOLAMENTO (ver PRD §3):
//   1. Prisma Client Extension ($extends) + AsyncLocalStorage:
//      injeta tenantId em toda query automaticamente (impede WHERE esquecido).
//   2. Postgres RLS: policy por tabela + SET LOCAL app.current_tenant
//      dentro da transação — o banco recusa cruzar tenants (defesa em profundidade).
//
// ÍNDICES: sempre LIDERADOS por tenantId (ex.: [tenantId, sku]) — cada tenant
// toca só a sua fatia do B-tree; volume dos outros não atrapalha.
//
// ESTOQUE (Opção B — dois saldos):
//   estoqueFechado (un) + estoqueAberto (ml/g da unidade em uso).
//   Receita com estoqueAberto==0 -> abre 1: fechado-=1, aberto+=conteudoPorUnidade.
//   Venda fechada não lê o aberto ("aberta não vende fechada" sai de graça).
//   % da aberta = estoqueAberto / conteudoPorUnidade.
// ============================================================

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // Neon pooled
  directUrl = env("DIRECT_URL") // Neon unpooled — usado nas migrations
}

// ============================================================
// CONTROLE / AUTH (mesmo banco)
// ============================================================

enum Plan {
  STARTER
  PRO
  MULTI
}

enum TenantStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  CANCELED
}

enum Role {
  OWNER
  ADMIN
  MEMBER
}

enum TipoOperacao {
  AUTONOMO
  MERCADINHO
  CONVENIENCIA_BEBIDAS
}

enum Atendimento {
  SELF_SERVICE
  OPERADOR_PDV
}

enum Topologia {
  LOCAL
  CD_ABASTECE
  MISTO
}

model Tenant {
  id        String @id @default(cuid())
  subdomain String @unique // x.app.com -> resolvido no middleware
  nome      String

  plano       Plan         @default(STARTER)
  status      TenantStatus @default(TRIAL)
  trialEndsAt DateTime?

  // Onboarding -> defaults
  tipoOperacao TipoOperacao?
  atendimento  Atendimento?
  topologia    Topologia?
  numPontos    Int?

  // Toggles de módulo (lidos no middleware/menu)
  moduloPdv      Boolean @default(false)
  moduloFiscal   Boolean @default(false)
  moduloComodato Boolean @default(false)
  moduloRota     Boolean @default(false)

  onboardingDone Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships      Membership[]
  subscription     Subscription?
  brands           Brand[]
  categories       Category[]
  subcategories    Subcategory[]
  fiscalProfiles   FiscalProfile[]
  storageLocations StorageLocation[]
  suppliers        Supplier[]
  products         Product[]
  tags             Tag[]
  sites            Site[]

  @@index([status])
}

model Membership {
  id        String   @id @default(cuid())
  userId    String
  tenantId  String
  role      Role     @default(OWNER)
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([tenantId])
}

model Subscription {
  id         String   @id @default(cuid())
  tenantId   String   @unique
  plano      Plan
  status     String
  gateway    String?
  externalId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// Auth.js (NextAuth v5). User é GLOBAL; vínculo com tenant = Membership.
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String? // provider Credentials
  createdAt     DateTime  @default(now())

  accounts    Account[]
  sessions    Session[]
  memberships Membership[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================
// NEGÓCIO (toda tabela carrega tenantId p/ RLS + índice liderado por tenantId)
// ============================================================

enum ProductType {
  SIMPLES
  COMBO
  PERSONALIZADO
  INSUMO
}

enum BaseUnit {
  UN
  ML
  G
}

enum RecipeType {
  DRINK
  PRATO
  OUTRO
}

enum StorageType {
  AMBIENTE
  REFRIGERADO
  CONGELADO
}

enum SalesChannel {
  IFOOD
  MERCADO_LIVRE
  PROPRIO
}

enum SiteType {
  LOJA
  CD
}

enum MovementType {
  ENTRADA
  SAIDA
  AJUSTE
  TRANSFERENCIA
  ABERTURA
  PRODUCAO
  PERDA
}

enum PurchaseType {
  MANUAL
  FORNECEDOR
}

enum SelectionType {
  UNICA
  MULTIPLA
}

// ── Fase 4 (Vendas & Checkout) ──────────────────────────────
enum SaleOrigin {
  PDV // operador no balcão
  TOTEM // self-service
  APP // app próprio (self-service)
}

enum SaleStatus {
  ABERTA // carrinho em andamento
  PAGA // finalizada (baixa aplicada)
  CANCELADA
}

enum PaymentMethod {
  DINHEIRO
  CARTAO_CREDITO
  CARTAO_DEBITO
  PIX
  OUTRO
}

enum PaymentStatus {
  PENDENTE // aguardando confirmação (PIX/totem)
  CONFIRMADO
  ESTORNADO
}

enum CashSessionStatus {
  ABERTA
  FECHADA
}

enum CashMovementType {
  ABERTURA
  SANGRIA // retirada de dinheiro
  SUPRIMENTO // reforço de dinheiro
  FECHAMENTO
}

model Brand {
  id              String @id @default(cuid())
  tenantId        String
  nome            String // exibição (maiúsculas na UI)
  nomeNormalizado String // uppercase+trim+sem pontuação+espaços colapsados

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([tenantId, nomeNormalizado])
  @@index([tenantId])
}

model Category {
  id        String @id @default(cuid())
  tenantId  String
  nome      String
  skuPrefix String // "BEB"

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subcategories Subcategory[]

  @@unique([tenantId, skuPrefix])
  @@index([tenantId])
}

model Subcategory {
  id                     String       @id @default(cuid())
  tenantId               String
  categoryId             String
  nome                   String
  skuPrefix              String // "CER" — derivado do nome automaticamente
  ativo                  Boolean      @default(true)
  defaultFiscalProfileId String?
  defaultStorageType     StorageType?

  tenant               Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category             Category       @relation(fields: [categoryId], references: [id])
  defaultFiscalProfile FiscalProfile? @relation(fields: [defaultFiscalProfileId], references: [id])
  products             Product[]

  @@unique([tenantId, categoryId, skuPrefix])
  @@index([tenantId])
  @@index([categoryId])
}

model FiscalProfile {
  id             String   @id @default(cuid())
  tenantId       String
  nome           String // "Cerveja ST – RS"
  ncm            String
  cest           String?
  origem         String   @default("0")
  csosn          String?
  cst            String?
  cstPis         String?
  cstCofins      String?
  aliquotaIcms   Decimal? @db.Decimal(5, 2)
  temSt          Boolean  @default(false)
  precisaRevisao Boolean  @default(false)

  tenant                 Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products               Product[]
  subcategoriesAsDefault Subcategory[]

  @@index([tenantId])
}

model StorageLocation {
  id       String      @id @default(cuid())
  tenantId String
  siteId   String?
  nome     String
  tipo     StorageType

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  site   Site?   @relation(fields: [siteId], references: [id])
  stocks Stock[]

  @@unique([tenantId, nome])
  @@index([tenantId])
  @@index([siteId])
}

model Supplier {
  id                   String   @id @default(cuid())
  tenantId             String
  cnpj                 String?
  razaoSocial          String
  nomeFantasia         String?
  email                String?
  telefone             String? // telefone/WhatsApp
  nomeContatoPrincipal String?
  website              String?
  cep                  String?
  logradouro           String?
  numero               String?
  complemento          String?
  bairro               String?
  municipio            String?
  uf                   String?
  ativo                Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products  ProductSupplier[]
  purchases Purchase[]

  @@unique([tenantId, cnpj])
  @@index([tenantId])
}

model ProductSupplier {
  id                 String   @id @default(cuid())
  tenantId           String
  productId          String
  supplierId         String
  codigoNoFornecedor String?
  custoFornecedor    Decimal? @db.Decimal(10, 2)
  isPrincipal        Boolean  @default(false)

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplier Supplier @relation(fields: [supplierId], references: [id])

  @@unique([productId, supplierId])
  @@index([tenantId])
  @@index([supplierId])
}

model Product {
  id            String      @id @default(cuid())
  tenantId      String
  tipo          ProductType @default(SIMPLES)
  ean           String?
  nome          String
  sku           String // BEB-CER-6489
  brandId       String?
  subcategoryId String?
  imagemUrl     String?

  unidadeBase        BaseUnit @default(UN)
  fracionavel        Boolean  @default(false)
  conteudoPorUnidade Decimal? @db.Decimal(10, 2)

  precoVenda Decimal? @db.Decimal(10, 2)
  custo      Decimal? @db.Decimal(10, 2)
  custoMedio Decimal? @db.Decimal(10, 2)

  fiscalProfileId String?
  restricaoIdade  Boolean @default(false) // +18
  ativo           Boolean @default(true)

  tipoReceita RecipeType?
  modoPreparo String?

  vendeOnline     Boolean  @default(false)
  pesoGramas      Int?
  alturaCm        Decimal? @db.Decimal(6, 2)
  larguraCm       Decimal? @db.Decimal(6, 2)
  comprimentoCm   Decimal? @db.Decimal(6, 2)
  descricaoOnline String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  brand         Brand?         @relation(fields: [brandId], references: [id])
  subcategory   Subcategory?   @relation(fields: [subcategoryId], references: [id])
  fiscalProfile FiscalProfile? @relation(fields: [fiscalProfileId], references: [id])

  stocks        Stock[]
  packagings    ProductPackaging[]
  components    ProductComponent[]    @relation("ParentProduct")
  usedInRecipes ProductComponent[]    @relation("ComponentProduct")
  componentGroups ProductComponentGroup[]
  variants      ProductVariant[]
  tags          ProductTag[]
  salesChannels ProductSalesChannel[]
  suppliers     ProductSupplier[]

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@index([tenantId, ean])
  @@index([brandId])
  @@index([subcategoryId])
}

model Stock {
  id         String  @id @default(cuid())
  tenantId   String
  productId  String
  siteId     String?
  locationId String?

  estoqueFechado Decimal @default(0) @db.Decimal(12, 3)
  estoqueAberto  Decimal @default(0) @db.Decimal(12, 3)
  estoqueMinimo  Decimal @default(0) @db.Decimal(12, 3)
  estoqueIdeal   Decimal @default(0) @db.Decimal(12, 3)

  product  Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  site     Site?            @relation(fields: [siteId], references: [id])
  location StorageLocation? @relation(fields: [locationId], references: [id])

  @@unique([productId, siteId])
  @@index([tenantId])
  @@index([siteId])
  @@index([locationId])
}

model ProductPackaging {
  id              String  @id @default(cuid())
  tenantId        String
  productId       String
  nome            String // "Fardo", "Caixa", "Engradado"
  ean             String?
  fatorConversao  Decimal @db.Decimal(10, 3) // quantas UNIDADES base contém
  isCompraDefault Boolean @default(false)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([productId])
}

model ProductComponent {
  id                 String   @id @default(cuid())
  tenantId           String
  parentProductId    String
  componentProductId String
  quantidade         Decimal  @db.Decimal(12, 3)
  unidade            BaseUnit
  groupId            String?
  isDefault          Boolean  @default(false)
  acrescenta         Boolean  @default(true)
  acrescimoPreco     Decimal? @db.Decimal(10, 2)

  parent    Product                   @relation("ParentProduct", fields: [parentProductId], references: [id], onDelete: Cascade)
  component Product                   @relation("ComponentProduct", fields: [componentProductId], references: [id])
  group     ProductComponentGroup?    @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([parentProductId])
  @@index([componentProductId])
  @@index([groupId])
}

model ProductComponentGroup {
  id              String        @id @default(cuid())
  tenantId        String
  parentProductId String
  nome            String
  obrigatoria     Boolean       @default(true)
  tipoSelecao     SelectionType @default(UNICA)
  maxSelecoes     Int?
  ordem           Int           @default(0)

  parent     Product          @relation(fields: [parentProductId], references: [id], onDelete: Cascade)
  components ProductComponent[]

  @@index([tenantId])
  @@index([parentProductId])
}

// ------------------------------------------------------------
// VARIAÇÃO DE TAMANHO (Fase 2) — só p/ PERSONALIZADO
// Tamanho de copo/porção como FATOR DE ESCALA sobre a ficha base.
// Doses por tamanho = quantidade do ProductComponent × fatorEscala.
// precoVenda nulo => derivado (preço base × fatorEscala).
// ------------------------------------------------------------

model ProductVariant {
  id          String   @id @default(cuid())
  tenantId    String
  productId   String // o PERSONALIZADO
  nome        String // "P", "M", "G", "300ml"...
  volumeMl    Decimal? @db.Decimal(10, 2) // tamanho do copo (drink)
  fatorEscala Decimal  @default(1) @db.Decimal(6, 3) // multiplica as doses da ficha base
  precoVenda  Decimal? @db.Decimal(10, 2) // nulo => derivado
  isDefault   Boolean  @default(false)
  ativo       Boolean  @default(true)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, nome])
  @@index([tenantId])
  @@index([productId])
}

model Tag {
  id       String @id @default(cuid())
  tenantId String
  nome     String

  tenant   Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products ProductTag[]

  @@unique([tenantId, nome])
  @@index([tenantId])
}

model ProductTag {
  tenantId  String
  productId String
  tagId     String

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([productId, tagId])
  @@index([tenantId])
  @@index([tagId])
}

model ProductSalesChannel {
  id             String       @id @default(cuid())
  tenantId       String
  productId      String
  canal          SalesChannel
  precoCanal     Decimal?     @db.Decimal(10, 2)
  descricaoCanal String?
  ativo          Boolean      @default(true)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, canal])
  @@index([tenantId])
}

// ============================================================
// FASE 3 — SITES, ESTOQUE E MOVIMENTAÇÃO
// ============================================================

model Site {
  id        String   @id @default(cuid())
  tenantId  String
  nome      String
  tipo      SiteType @default(LOJA)
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stocks           Stock[]
  storageLocations StorageLocation[]
  purchases        Purchase[]
  productions      Production[]
  transfersOut     Transfer[]        @relation("TransferOrigem")
  transfersIn      Transfer[]        @relation("TransferDestino")
  sales            Sale[]
  cashSessions     CashSession[]
  paymentMethods   SitePaymentMethod[]

  @@unique([tenantId, nome])
  @@index([tenantId])
}

// Razão append-only: toda mudança de saldo = uma linha.
// Stock (saldo corrente por produto × site) é atualizado na mesma transação.
model StockMovement {
  id        String       @id @default(cuid())
  tenantId  String
  siteId    String
  productId String
  tipo      MovementType

  deltaFechado Decimal @default(0) @db.Decimal(12, 3)
  deltaAberto  Decimal @default(0) @db.Decimal(12, 3)

  custoUnitario Decimal? @db.Decimal(10, 2)

  purchaseId   String?
  transferId   String?
  productionId String?
  saleId       String?
  observacao   String?

  createdAt DateTime @default(now())
  createdBy String?

  @@index([tenantId])
  @@index([siteId])
  @@index([productId])
  @@index([tipo])
  @@index([transferId])
  @@index([productionId])
  @@index([saleId])
  @@index([createdAt])
}

model Purchase {
  id         String       @id @default(cuid())
  tenantId   String
  siteId     String
  tipo       PurchaseType @default(MANUAL)
  supplierId String?
  numeroNota String?
  data       DateTime     @default(now())
  observacao String?
  createdAt  DateTime     @default(now())

  site     Site           @relation(fields: [siteId], references: [id])
  supplier Supplier?      @relation(fields: [supplierId], references: [id])
  items    PurchaseItem[]

  @@index([tenantId])
  @@index([siteId])
  @@index([supplierId])
}

model PurchaseItem {
  id          String  @id @default(cuid())
  tenantId    String
  purchaseId  String
  productId   String
  packagingId String?
  quantidade  Decimal @db.Decimal(12, 3)
  custoTotal  Decimal @db.Decimal(12, 2)

  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([purchaseId])
  @@index([productId])
}

model Transfer {
  id            String   @id @default(cuid())
  tenantId      String
  origemSiteId  String
  destinoSiteId String
  data          DateTime @default(now())
  observacao    String?
  createdAt     DateTime @default(now())

  origem  Site           @relation("TransferOrigem", fields: [origemSiteId], references: [id])
  destino Site           @relation("TransferDestino", fields: [destinoSiteId], references: [id])
  items   TransferItem[]

  @@index([tenantId])
  @@index([origemSiteId])
  @@index([destinoSiteId])
}

model TransferItem {
  id         String  @id @default(cuid())
  tenantId   String
  transferId String
  productId  String
  quantidade Decimal @db.Decimal(12, 3)

  transfer Transfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([transferId])
  @@index([productId])
}

model Production {
  id         String   @id @default(cuid())
  tenantId   String
  siteId     String
  productId  String
  variantId  String?
  quantidade Int      @default(1)
  saleId     String? // se a produção foi disparada por uma venda
  data       DateTime @default(now())
  observacao String?
  createdAt  DateTime @default(now())

  site Site @relation(fields: [siteId], references: [id])

  @@index([tenantId])
  @@index([siteId])
  @@index([productId])
  @@index([saleId])
}

// ============================================================
// FASE 4 — VENDAS / CHECKOUT
// Dois sabores sobre a mesma base: PDV (operador) e self-service (totem/app).
// Finalizar a venda dispara a baixa de estoque (SAIDA / PRODUCAO) no site.
// ============================================================

model Sale {
  id             String     @id @default(cuid())
  tenantId       String
  siteId         String
  origem         SaleOrigin @default(PDV)
  status         SaleStatus @default(ABERTA)
  cashSessionId  String? // só PDV
  operatorUserId String? // só PDV

  subtotal Decimal @default(0) @db.Decimal(12, 2)
  desconto Decimal @default(0) @db.Decimal(12, 2)
  total    Decimal @default(0) @db.Decimal(12, 2)

  maiorIdadeConfirmada Boolean @default(false) // +18 confirmado no fechamento

  createdAt DateTime  @default(now())
  paidAt    DateTime?

  site        Site         @relation(fields: [siteId], references: [id])
  cashSession CashSession? @relation(fields: [cashSessionId], references: [id])
  items       SaleItem[]
  payments    Payment[]

  @@index([tenantId])
  @@index([siteId])
  @@index([cashSessionId])
  @@index([status])
  @@index([createdAt])
}

model SaleItem {
  id            String  @id @default(cuid())
  tenantId      String
  saleId        String
  productId     String
  variantId     String?
  quantidade    Decimal @db.Decimal(12, 3)
  precoUnitario Decimal @db.Decimal(10, 2)
  desconto      Decimal @default(0) @db.Decimal(10, 2)
  total         Decimal @db.Decimal(12, 2)

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([saleId])
  @@index([productId])
}

model Payment {
  id         String        @id @default(cuid())
  tenantId   String
  saleId     String
  metodo     PaymentMethod
  status     PaymentStatus @default(CONFIRMADO)
  valor      Decimal       @db.Decimal(12, 2)
  troco      Decimal?      @db.Decimal(10, 2) // dinheiro
  gateway    String?
  externalId String? // ref PIX/cartão
  createdAt  DateTime      @default(now())

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([saleId])
  @@index([status])
}

model CashSession {
  id              String            @id @default(cuid())
  tenantId        String
  siteId          String
  operatorUserId  String
  status          CashSessionStatus @default(ABERTA)
  valorAbertura   Decimal           @db.Decimal(12, 2)
  valorFechamento Decimal?          @db.Decimal(12, 2) // contado no fechamento
  abertaEm        DateTime          @default(now())
  fechadaEm       DateTime?

  site      Site           @relation(fields: [siteId], references: [id])
  sales     Sale[]
  movements CashMovement[]

  @@index([tenantId])
  @@index([siteId])
  @@index([status])
}

model CashMovement {
  id            String           @id @default(cuid())
  tenantId      String
  cashSessionId String
  tipo          CashMovementType
  valor         Decimal          @db.Decimal(12, 2)
  motivo        String?
  createdAt     DateTime         @default(now())

  cashSession CashSession @relation(fields: [cashSessionId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([cashSessionId])
}

// Métodos de pagamento aceitos por site (defaults vêm do preset de atendimento)
model SitePaymentMethod {
  id       String        @id @default(cuid())
  tenantId String
  siteId   String
  metodo   PaymentMethod
  ativo    Boolean       @default(true)

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, metodo])
  @@index([tenantId])
}
