// ============================================================
// NoHub Market — Schema único (row-level multi-tenant)
// Um schema físico, um PrismaClient. Isolamento por `tenantId`.
//
// DUAS CAMADAS DE ISOLAMENTO (ver PRD §3):
//   1. Prisma Client Extension ($extends) + AsyncLocalStorage:
//      injeta tenantId em toda query automaticamente (impede WHERE esquecido).
//   2. Postgres RLS: policy por tabela + SET LOCAL app.current_tenant
//      dentro da transação — o banco recusa cruzar tenants (defesa em profundidade).
//
// ÍNDICES: sempre LIDERADOS por tenantId (ex.: [tenantId, sku]) — cada tenant
// toca só a sua fatia do B-tree; volume dos outros não atrapalha.
//
// ESTOQUE (Opção B — dois saldos):
//   estoqueFechado (un) + estoqueAberto (ml/g da unidade em uso).
//   Receita com estoqueAberto==0 -> abre 1: fechado-=1, aberto+=conteudoPorUnidade.
//   Venda fechada não lê o aberto ("aberta não vende fechada" sai de graça).
//   % da aberta = estoqueAberto / conteudoPorUnidade.
// ============================================================

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // Neon pooled
  directUrl = env("DIRECT_URL") // Neon unpooled — usado nas migrations
}

// ============================================================
// CONTROLE / AUTH (mesmo banco)
// ============================================================

/// Planos de venda. O plano define o TETO do que o tenant pode usar; os toggles
/// `modulo*` definem o que ele de fato ligou. Add-ons (Tenant.addons) destravam
/// features fora do plano — usados no que tem custo variável (fiscal, totem).
/// Matriz plano → features → limites: src/lib/planos.ts (fonte única).
enum Plan {
  PRATA
  OURO
  DIAMANTE
}

enum TenantStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  CANCELED
}

/// Perfis de acesso. ADMINISTRADOR é sempre do tenant inteiro (siteId null);
/// os demais são operacionais e podem ser restritos a uma loja.
enum Perfil {
  ADMINISTRADOR
  ESTOQUISTA
  CAIXA
  FINANCEIRO
  CONTADOR
}

enum TipoOperacao {
  AUTONOMO
  MERCADINHO
  CONVENIENCIA_BEBIDAS
}

enum Atendimento {
  SELF_SERVICE
  OPERADOR_PDV
}

enum Topologia {
  LOCAL
  CD_ABASTECE
  MISTO
}

model Tenant {
  id        String @id @default(cuid())
  subdomain String @unique // x.app.com -> resolvido no middleware
  nome      String

  plano       Plan         @default(PRATA)
  status      TenantStatus @default(TRIAL)
  trialEndsAt DateTime?

  /// Add-ons contratados por fora do plano (slugs de `Addon`, src/lib/planos.ts).
  /// Existem para o que tem custo variável ou por unidade: emissão fiscal
  /// (a Nuvem Fiscal cobra por documento) e autoatendimento (por totem).
  addons String[] @default([])

  /// Lojas contratadas além das que o plano já inclui (add-on `loja-extra`).
  lojasExtras Int @default(0)

  // Perfil da empresa (Configurações → Empresa)
  cnpj         String?
  razaoSocial  String?
  logoUrl      String? // logo da loja (exibida no totem/autoatendimento)
  telefone     String?
  emailContato String?
  cep          String?
  rua          String?
  numero       String?
  cidade       String?
  estado       String?

  // Onboarding -> defaults
  tipoOperacao TipoOperacao?
  atendimento  Atendimento?
  topologia    Topologia?
  numPontos    Int?

  // Toggles de módulo (lidos no middleware/menu)
  moduloPdv             Boolean @default(false)
  moduloFiscal          Boolean @default(false)
  moduloComodato        Boolean @default(false)
  moduloRota            Boolean @default(false)
  moduloAutoatendimento Boolean @default(false)

  // Autoatendimento (totem): PIN para sair do modo quiosque. null = saída livre.
  totemPinHash String?

  // Distribuição CD→loja: se true, recebimento exige contagem na loja (gera
  // estoque em trânsito); se false, expedição auto-confirma o recebimento.
  recebimentoExigeContagem Boolean @default(false)

  // Fidelização / CRM: envio automático de cupom (risco + aniversário) via
  // WhatsApp. Desligado por padrão — o operador liga em Configurações.
  cupomAutomatico Boolean @default(false)
  cupomDiasRisco  Int     @default(25) // dias sem comprar → cliente em risco

  // Níveis do cliente por total gasto acumulado (Cobre é o nível-base, sempre
  // R$ 0 — não configurável). Ajustável em Configurações → Fidelização.
  tierBronzeMin   Int @default(200)
  tierPrataMin    Int @default(500)
  tierOuroMin     Int @default(2000)
  tierDiamanteMin Int @default(5000)

  // Estoque (Configurações → Estoque e alertas)
  estoqueMinimoPadrao Int @default(0) // pré-preenche o mínimo ao cadastrar produto
  produtoParadoDias   Int @default(45) // dias sem movimentação → alerta "parado"

  // Caixa / PDV (Configurações → Caixa)
  caixaFundoTroco   Decimal? @db.Decimal(10, 2) // sugestão de abertura
  caixaLimiteGaveta Decimal? @db.Decimal(10, 2) // acima disso, sugere sangria

  // Sino de alertas: categorias desligadas pelo operador (AlertCategory[])
  alertasDesativados String[] @default([])

  onboardingDone Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships      Membership[]
  invites          Invite[]
  subscription     Subscription?
  brands           Brand[]
  categories       Category[]
  subcategories    Subcategory[]
  fiscalProfiles   FiscalProfile[]
  storageLocations StorageLocation[]
  suppliers        Supplier[]
  products         Product[]
  tags             Tag[]
  sites            Site[]
  customers        Customer[]
  comodatoAssets   ComodatoAsset[]
  containerTypes   ContainerType[]
  paymentProvider  PaymentProviderConfig?
  fiscalConfig     FiscalConfig?
  fiscalEmitentes  FiscalEmitente[]

  @@index([status])
}

model Membership {
  id       String @id @default(cuid())
  userId   String
  tenantId String

  /// Dono da conta: responde pela cobrança e não pode ser removido/desativado.
  /// NÃO é um perfil — poder vem de MembershipAccess.
  proprietario Boolean   @default(false)
  ativo        Boolean   @default(true)
  ultimoAcesso DateTime?

  createdAt DateTime @default(now())

  acessos MembershipAccess[]
  user    User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant  Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([tenantId])
}

/// Um acesso = um perfil, opcionalmente restrito a uma loja.
/// siteId null = vale para todas as lojas. Uma pessoa pode ter vários.
/// Ex.: { ESTOQUISTA, null } + { CAIXA, "loja-centro" }.
model MembershipAccess {
  id           String   @id @default(cuid())
  tenantId     String
  membershipId String
  perfil       Perfil
  siteId       String?
  criadoEm     DateTime @default(now())

  membership Membership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  site       Site?      @relation(fields: [siteId], references: [id], onDelete: Cascade)

  // Atenção: NULL não colide em Postgres — o índice parcial que impede duplicar
  // o acesso global está na migration (MembershipAccess_global_key).
  @@unique([membershipId, perfil, siteId])
  @@index([tenantId, siteId])
}

// Convite de equipe (tabela de CONTROLE, como Membership): criado em
// Configurações → Usuários; consumido no signup/OAuth quando o e-mail bate.
model Invite {
  id       String @id @default(cuid())
  tenantId String
  email    String

  /// Acessos que a pessoa recebe ao aceitar: [{ perfil, siteId | null }, …].
  /// Mesmo formato de MembershipAccess — validado por Zod antes de gravar.
  acessos Json @default("[]")

  /// Segredo do link /convite/<token>. Trocado a cada reenvio.
  token       String   @unique
  expiresAt   DateTime
  /// Quem convidou (User global) — só para exibir na tela.
  criadoPorId String?

  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@index([email])
}

model Subscription {
  id         String   @id @default(cuid())
  tenantId   String   @unique
  plano      Plan
  status     String
  gateway    String?
  externalId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// Auth.js (NextAuth v5). User é GLOBAL; vínculo com tenant = Membership.
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String? // provider Credentials
  createdAt     DateTime  @default(now())

  accounts    Account[]
  sessions    Session[]
  memberships Membership[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================
// NEGÓCIO (toda tabela carrega tenantId p/ RLS + índice liderado por tenantId)
// ============================================================

enum ProductType {
  SIMPLES
  COMBO
  PERSONALIZADO
  INSUMO
}

enum BaseUnit {
  UN
  ML
  G
}

enum RecipeType {
  DRINK
  PRATO
  OUTRO
}

enum StorageType {
  AMBIENTE
  REFRIGERADO
  CONGELADO
}

enum SalesChannel {
  IFOOD
  MERCADO_LIVRE
  PROPRIO
}

enum SiteType {
  LOJA
  CD
}

enum MovementType {
  ENTRADA
  SAIDA
  AJUSTE
  TRANSFERENCIA
  ABERTURA
  PRODUCAO
  PERDA
  DEVOLUCAO_CLIENTE // cliente devolve → entra no estoque (+)
  DEVOLUCAO_FORNECEDOR // devolvido ao fornecedor → sai do estoque (−)
}

enum PurchaseType {
  MANUAL
  FORNECEDOR
}

enum PurchaseMotivo {
  COMPRA_SEM_PEDIDO
  BONIFICACAO
  ESTOQUE_INICIAL
  TRANSFERENCIA
  BRINDE
  TROCA
  AMOSTRA
  SERVICO
}

// Tipo do item dentro do pedido de compra — separa o que é cobrado pelo
// fornecedor (COMPRA) do que entra no estoque sem custo. Modelado como enum
// (não checkbox) para crescer sem alterar a estrutura do pedido.
enum TipoItemPedido {
  COMPRA
  BONIFICACAO
  BRINDE
  TROCA
  AMOSTRA
  SERVICO
}

// Motivo específico de um item não-COMPRA (hoje só bonificação usa).
enum MotivoBonificacao {
  COMERCIAL
  CAMPANHA
  REPOSICAO
  TROCA
  CORTESIA
  OUTRO
}

enum PurchaseOrderStatus {
  RASCUNHO // em elaboração ⚪
  ENVIADO // enviado ao fornecedor 🔵
  AGUARDANDO // confirmado pelo fornecedor, aguardando entrega 🟡
  EM_TRANSITO // mercadoria a caminho 🟣
  RECEBIDO_PARCIAL // recebimento pendente (chegou em parte) 🟠
  RECEBIDO // concluído ✅
  CANCELADO // 🔴
}

enum RequisicaoStatus {
  ABERTA // loja pediu, aguardando o CD separar
  ATENDIDA // CD separou/expediu (gerou Transfer)
  CANCELADA
}

enum TransferStatus {
  SEPARANDO // criado, ainda não baixou do CD
  EXPEDIDO // baixou do CD, em trânsito (aguarda recebimento na loja)
  RECEBIDO // somou na loja (conferido ou auto-confirmado)
  CANCELADA
}

enum InventoryStatus {
  PROGRAMADO // agendado, ainda sem contagem
  ABERTO // contagem em andamento
  FECHADO // contado e ajustado
  CANCELADO
}

enum SelectionType {
  UNICA
  MULTIPLA
}

// ── Fase 4 (Vendas & Checkout) ──────────────────────────────
enum SaleOrigin {
  PDV // operador no balcão
  TOTEM // self-service
  APP // app próprio (self-service)
}

enum SaleStatus {
  ABERTA // carrinho em andamento
  PAGA // finalizada (baixa aplicada)
  CANCELADA
}

enum PaymentMethod {
  DINHEIRO
  CARTAO_CREDITO
  CARTAO_DEBITO
  PIX
  OUTRO
}

enum PaymentStatus {
  PENDENTE // aguardando confirmação (PIX/totem)
  PROCESSANDO // enviado ao terminal de cartão — aguardando adquirente
  CONFIRMADO
  RECUSADO // adquirente recusou (cartão)
  EXPIRADO // cobrança PIX expirou sem pagamento
  CANCELADO // operador cancelou antes da confirmação
  ESTORNADO
}

// Provedor de pagamento integrado (PIX dinâmico / maquininha).
enum PaymentProviderKind {
  MERCADO_PAGO
  STONE // PIX via Pagar.me (grupo Stone); cartão continua manual (sem API cloud de terminal)
  PAGSEGURO // PIX via API Pedidos PagBank; cartão continua manual (sem API cloud de terminal)
  SIMULADO // dev: aprova sozinho após alguns segundos
}

enum PaymentAmbiente {
  PRODUCAO
  SANDBOX // testes com token/API sandbox do PagBank — host de API diferente
}

enum CashSessionStatus {
  ABERTA
  FECHADA
}

enum CashMovementType {
  ABERTURA
  SANGRIA // retirada de dinheiro
  SUPRIMENTO // reforço de dinheiro
  FECHAMENTO
}

enum Sexo {
  MASCULINO
  FEMININO
  OUTRO
}

// Motivo do cupom enviado — dirige a mensagem e evita reenvio duplicado.
enum CouponReason {
  RISCO // cliente ativo parou de comprar
  ANIVERSARIO
  MANUAL
}

enum ComodatoAssetStatus {
  DISPONIVEL
  EMPRESTADO
  MANUTENCAO
  BAIXADO // fora de uso (vendido, perdido, sucata)
}

enum ContainerMovementType {
  ENTREGA // entregue ao cliente (saldo do cliente sobe)
  DEVOLUCAO // devolvido pelo cliente (saldo desce)
  AJUSTE // acerto manual (quantidade assinada)
}

model Brand {
  id              String @id @default(cuid())
  tenantId        String
  nome            String // exibição (maiúsculas na UI)
  nomeNormalizado String // uppercase+trim+sem pontuação+espaços colapsados

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([tenantId, nomeNormalizado])
  @@index([tenantId])
}

model Category {
  id        String @id @default(cuid())
  tenantId  String
  nome      String
  skuPrefix String // "BEB"

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subcategories Subcategory[]
  inventories   Inventory[]

  @@unique([tenantId, skuPrefix])
  @@index([tenantId])
}

model Subcategory {
  id                     String       @id @default(cuid())
  tenantId               String
  categoryId             String
  nome                   String
  skuPrefix              String // "CER" — derivado do nome automaticamente
  ativo                  Boolean      @default(true)
  defaultFiscalProfileId String?
  defaultStorageType     StorageType?

  tenant               Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category             Category       @relation(fields: [categoryId], references: [id])
  defaultFiscalProfile FiscalProfile? @relation(fields: [defaultFiscalProfileId], references: [id])
  products             Product[]

  @@unique([tenantId, categoryId, skuPrefix])
  @@index([tenantId])
  @@index([categoryId])
}

// Classificação fiscal reutilizável. É a FONTE do tributário: o produto
// aponta para um perfil em vez de repetir NCM/CST/CFOP em cada SKU (um
// mercadinho tem milhares de produtos e ~20 perfis). O que é por-item
// (GTIN tributável, fator de conversão) fica no Product.
model FiscalProfile {
  id              String   @id @default(cuid())
  tenantId        String
  nome            String // "Cerveja ST – RS"
  ncm             String
  cest            String?
  origem          String   @default("0")
  csosn           String?
  cst             String?
  cstPis          String?
  cstCofins       String?
  cstIpi          String?
  aliquotaIcms    Decimal? @db.Decimal(5, 2)
  aliquotaPis     Decimal? @db.Decimal(5, 2)
  aliquotaCofins  Decimal? @db.Decimal(5, 2)
  aliquotaIpi     Decimal? @db.Decimal(5, 2)
  // CFOP é da operação, não do SKU — mora aqui. Dentro do estado; a emissão
  // troca o 5xxx por 6xxx quando a UF do destinatário difere da do emitente.
  cfopSaida       String?
  cfopEntrada     String?
  codigoBeneficio String? // cBenef (UFs que exigem: RS, BA, PE…)
  temSt           Boolean  @default(false)
  precisaRevisao  Boolean  @default(false)

  tenant                 Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products               Product[]
  subcategoriesAsDefault Subcategory[]

  @@index([tenantId])
}

model StorageLocation {
  id       String      @id @default(cuid())
  tenantId String
  siteId   String
  nome     String
  tipo     StorageType
  ativo    Boolean     @default(true)

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  site   Site    @relation(fields: [siteId], references: [id])
  stocks Stock[]

  @@unique([tenantId, siteId, nome])
  @@index([tenantId])
  @@index([siteId])
}

model Supplier {
  id                   String       @id @default(cuid())
  tenantId             String
  cnpj                 String?
  razaoSocial          String
  nomeFantasia         String?
  email                String?
  telefone             String? // telefone/WhatsApp
  nomeContatoPrincipal String?
  website              String?
  logoUrl              String?
  cep                  String?
  logradouro           String?
  numero               String?
  complemento          String?
  bairro               String?
  municipio            String?
  codigoMunicipio      String? // IBGE (7 dígitos) — vem do XML de entrada
  uf                   String?
  ie                   String? // inscrição estadual
  indicadorIE          IndicadorIE?
  pedidoMinimo         Decimal?     @db.Decimal(12, 2) // valor mínimo de pedido exigido pelo fornecedor
  ativo                Boolean      @default(true)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products        ProductSupplier[]
  purchases       Purchase[]
  purchaseOrders  PurchaseOrder[]
  fiscalDocuments FiscalDocument[]
  fiscalInbounds  FiscalInbound[]
  itemMaps        SupplierItemMap[]

  @@unique([tenantId, cnpj])
  @@index([tenantId])
}

model ProductSupplier {
  id                 String   @id @default(cuid())
  tenantId           String
  productId          String
  supplierId         String
  codigoNoFornecedor String?
  custoFornecedor    Decimal? @db.Decimal(10, 2)
  isPrincipal        Boolean  @default(false)

  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplier Supplier @relation(fields: [supplierId], references: [id])

  @@unique([productId, supplierId])
  @@index([tenantId])
  @@index([supplierId])
}

model Product {
  id            String      @id @default(cuid())
  tenantId      String
  tipo          ProductType @default(SIMPLES)
  ean           String?
  nome          String
  sku           String // BEB-CER-6489
  brandId       String?
  subcategoryId String?
  imagemUrl     String?

  unidadeBase        BaseUnit @default(UN)
  fracionavel        Boolean  @default(false)
  conteudoPorUnidade Decimal? @db.Decimal(10, 2)

  precoVenda Decimal? @db.Decimal(10, 2)
  custo      Decimal? @db.Decimal(10, 2)
  custoMedio Decimal? @db.Decimal(10, 2)

  fiscalProfileId    String?
  // Dados fiscais POR ITEM (o resto herda do FiscalProfile — não duplicar).
  // Recolhidos na UI: quem não vende por unidade tributável diferente nunca vê.
  gtinTributavel     String? // cEANTrib — difere do EAN quando se vende fração
  unidadeTributavel  String? // uTrib ("KG", "L") quando ≠ da unidade de venda
  fatorConversaoTrib Decimal? @db.Decimal(12, 4) // qTrib = quantidade × fator
  codigoAnp          String? // combustíveis
  restricaoIdade     Boolean  @default(false) // +18
  ativo              Boolean  @default(true)
  controlaEstoque    Boolean  @default(true) // false = INSUMO fora do controle de estoque (não aparece em /estoque)

  tipoReceita RecipeType?
  copoMl      Decimal?    @db.Decimal(10, 2) // tamanho do copo (drink) — tamanho único
  modoPreparo String?

  vendeOnline     Boolean  @default(false)
  pesoGramas      Int?
  alturaCm        Decimal? @db.Decimal(6, 2)
  larguraCm       Decimal? @db.Decimal(6, 2)
  comprimentoCm   Decimal? @db.Decimal(6, 2)
  descricaoOnline String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  brand         Brand?         @relation(fields: [brandId], references: [id])
  subcategory   Subcategory?   @relation(fields: [subcategoryId], references: [id])
  fiscalProfile FiscalProfile? @relation(fields: [fiscalProfileId], references: [id])

  stocks          Stock[]
  packagings      ProductPackaging[]
  components      ProductComponent[]      @relation("ParentProduct")
  usedInRecipes   ProductComponent[]      @relation("ComponentProduct")
  componentGroups ProductComponentGroup[]
  variants        ProductVariant[]
  tags            ProductTag[]
  salesChannels   ProductSalesChannel[]
  suppliers       ProductSupplier[]

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@index([tenantId, ean])
  @@index([brandId])
  @@index([subcategoryId])
}

model Stock {
  id         String  @id @default(cuid())
  tenantId   String
  productId  String
  siteId     String?
  locationId String?

  estoqueFechado Decimal @default(0) @db.Decimal(12, 3)
  estoqueAberto  Decimal @default(0) @db.Decimal(12, 3)
  estoqueMinimo  Decimal @default(0) @db.Decimal(12, 3)
  estoqueIdeal   Decimal @default(0) @db.Decimal(12, 3)

  product  Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  site     Site?            @relation(fields: [siteId], references: [id])
  location StorageLocation? @relation(fields: [locationId], references: [id])

  @@unique([productId, siteId])
  @@index([tenantId])
  @@index([siteId])
  @@index([locationId])
}

model ProductPackaging {
  id              String  @id @default(cuid())
  tenantId        String
  productId       String
  nome            String // "Fardo", "Caixa", "Engradado"
  ean             String?
  fatorConversao  Decimal @db.Decimal(10, 3) // quantas UNIDADES base contém
  isCompraDefault Boolean @default(false)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([productId])
}

model ProductComponent {
  id                 String   @id @default(cuid())
  tenantId           String
  parentProductId    String
  componentProductId String
  quantidade         Decimal  @db.Decimal(12, 3)
  unidade            BaseUnit
  groupId            String?
  isDefault          Boolean  @default(false)
  acrescenta         Boolean  @default(true)
  acrescimoPreco     Decimal? @db.Decimal(10, 2)

  parent    Product                @relation("ParentProduct", fields: [parentProductId], references: [id], onDelete: Cascade)
  component Product                @relation("ComponentProduct", fields: [componentProductId], references: [id])
  group     ProductComponentGroup? @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([parentProductId])
  @@index([componentProductId])
  @@index([groupId])
}

model ProductComponentGroup {
  id              String        @id @default(cuid())
  tenantId        String
  parentProductId String
  nome            String
  obrigatoria     Boolean       @default(true)
  tipoSelecao     SelectionType @default(UNICA)
  maxSelecoes     Int?
  ordem           Int           @default(0)

  parent     Product            @relation(fields: [parentProductId], references: [id], onDelete: Cascade)
  components ProductComponent[]

  @@index([tenantId])
  @@index([parentProductId])
}

// ------------------------------------------------------------
// VARIAÇÃO DE TAMANHO (Fase 2) — só p/ PERSONALIZADO
// Tamanho de copo/porção como FATOR DE ESCALA sobre a ficha base.
// Doses por tamanho = quantidade do ProductComponent × fatorEscala.
// precoVenda nulo => derivado (preço base × fatorEscala).
// ------------------------------------------------------------

model ProductVariant {
  id          String   @id @default(cuid())
  tenantId    String
  productId   String // o PERSONALIZADO
  nome        String // "P", "M", "G", "300ml"...
  volumeMl    Decimal? @db.Decimal(10, 2) // tamanho do copo (drink)
  fatorEscala Decimal  @default(1) @db.Decimal(6, 3) // multiplica as doses da ficha base
  precoVenda  Decimal? @db.Decimal(10, 2) // nulo => derivado
  isDefault   Boolean  @default(false)
  ativo       Boolean  @default(true)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, nome])
  @@index([tenantId])
  @@index([productId])
}

model Tag {
  id       String @id @default(cuid())
  tenantId String
  nome     String

  tenant   Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products ProductTag[]

  @@unique([tenantId, nome])
  @@index([tenantId])
}

model ProductTag {
  tenantId  String
  productId String
  tagId     String

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([productId, tagId])
  @@index([tenantId])
  @@index([tagId])
}

model ProductSalesChannel {
  id             String       @id @default(cuid())
  tenantId       String
  productId      String
  canal          SalesChannel
  precoCanal     Decimal?     @db.Decimal(10, 2)
  descricaoCanal String?
  ativo          Boolean      @default(true)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, canal])
  @@index([tenantId])
}

// ============================================================
// FASE 3 — SITES, ESTOQUE E MOVIMENTAÇÃO
// ============================================================

model Site {
  id       String   @id @default(cuid())
  tenantId String
  nome     String
  tipo     SiteType @default(LOJA)
  ativo    Boolean  @default(true)

  // Endereço (opcional)
  cep    String?
  rua    String?
  numero String?
  cidade String?
  estado String?

  // Estoque: próprio ou abastecido por CD
  estoquePropio   Boolean @default(true)
  cdAbastecedorId String?

  // Venda restrita p/ maiores de 18 (PDV): só se aplica a LOJA — CD não vende.
  controleIdade Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cdAbastecedor      Site?               @relation("CDAbastecimento", fields: [cdAbastecedorId], references: [id], onDelete: SetNull)
  lojasCom           Site[]              @relation("CDAbastecimento")
  stocks             Stock[]
  storageLocations   StorageLocation[]
  purchases          Purchase[]
  purchaseOrders     PurchaseOrder[]
  productions        Production[]
  transfersOut       Transfer[]          @relation("TransferOrigem")
  transfersIn        Transfer[]          @relation("TransferDestino")
  requisicoesOrigem  Requisicao[]        @relation("RequisicaoOrigem")
  requisicoesDestino Requisicao[]        @relation("RequisicaoDestino")
  inventories        Inventory[]
  sales              Sale[]
  cashSessions       CashSession[]
  paymentMethods     SitePaymentMethod[]
  acessos            MembershipAccess[]
  totemDevices       TotemDevice[]
  paymentTerminals   PaymentTerminal[]
  fiscalEmitente     FiscalEmitente?
  fiscalSeries       FiscalSerie[]
  fiscalDocuments    FiscalDocument[]
  fiscalInbounds     FiscalInbound[]

  @@unique([tenantId, nome])
  @@index([tenantId])
  @@index([cdAbastecedorId])
}

// Razão append-only: toda mudança de saldo = uma linha.
// Stock (saldo corrente por produto × site) é atualizado na mesma transação.
model StockMovement {
  id        String       @id @default(cuid())
  tenantId  String
  siteId    String
  productId String
  tipo      MovementType

  deltaFechado Decimal @default(0) @db.Decimal(12, 3)
  deltaAberto  Decimal @default(0) @db.Decimal(12, 3)

  custoUnitario Decimal? @db.Decimal(10, 2)

  purchaseId   String?
  transferId   String?
  productionId String?
  saleId       String?
  observacao   String?

  createdAt DateTime @default(now())
  createdBy String?

  @@index([tenantId])
  @@index([siteId])
  @@index([productId])
  @@index([tipo])
  @@index([transferId])
  @@index([productionId])
  @@index([saleId])
  @@index([createdAt])
}

model Purchase {
  id              String          @id @default(cuid())
  tenantId        String
  siteId          String
  tipo            PurchaseType    @default(MANUAL)
  motivo          PurchaseMotivo?
  supplierId      String?
  purchaseOrderId String? // entrada gerada pela conferência de um pedido de compra
  numeroNota      String?
  data            DateTime        @default(now())
  observacao      String?
  createdAt       DateTime        @default(now())
  createdBy       String?

  site          Site             @relation(fields: [siteId], references: [id])
  supplier      Supplier?        @relation(fields: [supplierId], references: [id])
  purchaseOrder PurchaseOrder?   @relation(fields: [purchaseOrderId], references: [id])
  items         PurchaseItem[]
  fiscalDocs    FiscalDocument[]
  fiscalInbound FiscalInbound?

  @@index([tenantId])
  @@index([siteId])
  @@index([supplierId])
  @@index([purchaseOrderId])
}

// Pedido de compra ao fornecedor (PC-00125). Ciclo: rascunho → enviado →
// aguardando → recebido (parcial/total). A conferência no recebimento gera
// a(s) Purchase(s) de entrada que somam no estoque e atualiza qtdRecebida.
model PurchaseOrder {
  id               String              @id @default(cuid())
  tenantId         String
  siteId           String // destino: onde a mercadoria entra
  supplierId       String
  numero           String // PC-00125 (sequencial por tenant)
  status           PurchaseOrderStatus @default(RASCUNHO)
  previsaoEntrega  DateTime?
  valorTotal       Decimal             @default(0) @db.Decimal(12, 2) // soma cacheada dos itens
  observacao       String?
  financeiroGerado Boolean             @default(false) // gancho Contas a Pagar (stub)
  enviadoEm        DateTime?
  confirmadoEm     DateTime?
  emTransitoEm     DateTime?
  recebidoEm       DateTime?
  canceladoEm      DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @default(now()) @updatedAt // última mudança (status, itens…)
  createdBy        String?

  site     Site                @relation(fields: [siteId], references: [id])
  supplier Supplier            @relation(fields: [supplierId], references: [id])
  items    PurchaseOrderItem[]
  entradas Purchase[]
  inbounds FiscalInbound[]

  @@unique([tenantId, numero])
  @@index([tenantId])
  @@index([siteId])
  @@index([supplierId])
  @@index([status])
}

model PurchaseOrderItem {
  id                String             @id @default(cuid())
  tenantId          String
  purchaseOrderId   String
  productId         String
  packagingId       String? // unidade de compra (caixa, fardo…)
  tipo              TipoItemPedido     @default(COMPRA)
  motivoBonificacao MotivoBonificacao? // só para tipo != COMPRA
  qtdPedida         Decimal            @db.Decimal(12, 3)
  custoUnitario     Decimal            @default(0) @db.Decimal(12, 2) // custo por unidade de compra — sempre 0 quando tipo != COMPRA
  qtdRecebida       Decimal            @default(0) @db.Decimal(12, 3) // acumulado conferido
  observacao        String? // nota do item ("trocar por validade longa", etc.)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([purchaseOrderId])
  @@index([productId])
}

model PurchaseItem {
  id          String  @id @default(cuid())
  tenantId    String
  purchaseId  String
  productId   String
  packagingId String?
  quantidade  Decimal @db.Decimal(12, 3)
  custoTotal  Decimal @db.Decimal(12, 2)

  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([purchaseId])
  @@index([productId])
}

model Transfer {
  id             String         @id @default(cuid())
  tenantId       String
  origemSiteId   String
  destinoSiteId  String
  status         TransferStatus @default(RECEBIDO) // default RECEBIDO p/ não quebrar linhas atômicas antigas
  requisicaoId   String?        @unique
  data           DateTime       @default(now())
  expedidoEm     DateTime?
  recebidoEm     DateTime?
  temDivergencia Boolean        @default(false)
  observacao     String?
  createdAt      DateTime       @default(now())
  createdBy      String?

  origem     Site           @relation("TransferOrigem", fields: [origemSiteId], references: [id])
  destino    Site           @relation("TransferDestino", fields: [destinoSiteId], references: [id])
  requisicao Requisicao?    @relation(fields: [requisicaoId], references: [id])
  items      TransferItem[]

  @@index([tenantId])
  @@index([origemSiteId])
  @@index([destinoSiteId])
  @@index([status])
}

model TransferItem {
  id          String   @id @default(cuid())
  tenantId    String
  transferId  String
  productId   String
  quantidade  Decimal  @db.Decimal(12, 3) // qtd solicitada/planejada na transferência
  qtdExpedida Decimal? @db.Decimal(12, 3) // baixado do CD na expedição
  qtdRecebida Decimal? @db.Decimal(12, 3) // contado na loja no recebimento

  transfer Transfer @relation(fields: [transferId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([transferId])
  @@index([productId])
}

// Requisição interna: loja (destino) pede ao CD (origem). Sem aprovação —
// cai direto pro CD separar/expedir, o que gera o Transfer ligado.
model Requisicao {
  id            String           @id @default(cuid())
  tenantId      String
  origemSiteId  String // CD que atende
  destinoSiteId String // loja que pede
  status        RequisicaoStatus @default(ABERTA)
  observacao    String?
  createdAt     DateTime         @default(now())
  createdBy     String?
  atendidaEm    DateTime?

  origem   Site             @relation("RequisicaoOrigem", fields: [origemSiteId], references: [id])
  destino  Site             @relation("RequisicaoDestino", fields: [destinoSiteId], references: [id])
  items    RequisicaoItem[]
  transfer Transfer?

  @@index([tenantId])
  @@index([origemSiteId])
  @@index([destinoSiteId])
  @@index([status])
}

model RequisicaoItem {
  id            String   @id @default(cuid())
  tenantId      String
  requisicaoId  String
  productId     String
  qtdSolicitada Decimal  @db.Decimal(12, 3)
  qtdAtendida   Decimal? @db.Decimal(12, 3) // CD pode separar menos se faltar saldo

  requisicao Requisicao @relation(fields: [requisicaoId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([requisicaoId])
  @@index([productId])
}

enum InventoryEscopo {
  COMPLETO // todo o estoque do site
  CATEGORIA // produtos de uma categoria
  PRODUTOS // lista específica de produtos
}

// Inventário (contagem). É programado primeiro (sem tirar snapshot); só ao
// iniciar (ação explícita do usuário) fotografa o saldo por produto no site.
// No fechamento, a divergência (contado − saldo atual) gera um AJUSTE no razão.
model Inventory {
  id               String          @id @default(cuid())
  tenantId         String
  siteId           String
  status           InventoryStatus @default(PROGRAMADO)
  escopoTipo       InventoryEscopo @default(COMPLETO)
  categoryId       String? // quando escopoTipo = CATEGORIA
  escopoProdutoIds String[]        @default([]) // quando escopoTipo = PRODUTOS (antes de iniciar)
  modoCego         Boolean         @default(false) // contador não vê o saldo do sistema até fechar
  dataProgramada   DateTime // data (+ horário, se informado) planejada para realizar
  recorrente       Boolean         @default(false) // ao fechar, agenda automaticamente a próxima ocorrência
  diasSemana       Int[]           @default([]) // 0=domingo..6=sábado — dias da recorrência semanal (pode ter mais de um)
  responsavelId    String? // userId do responsável designado (opcional)
  observacao       String?
  createdAt        DateTime        @default(now())
  createdBy        String?
  iniciadoEm       DateTime? // quando a contagem foi de fato aberta (snapshot tirado)
  fechadoEm        DateTime?
  fechadoPor       String? // userId de quem finalizou a contagem

  site     Site            @relation(fields: [siteId], references: [id])
  category Category?       @relation(fields: [categoryId], references: [id])
  items    InventoryItem[]

  @@index([tenantId])
  @@index([siteId])
  @@index([status])
}

model InventoryItem {
  id          String   @id @default(cuid())
  tenantId    String
  inventoryId String
  productId   String
  qtdSistema  Decimal  @db.Decimal(12, 3) // snapshot na abertura
  qtdContada  Decimal? @db.Decimal(12, 3) // contagem física

  inventory Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([inventoryId])
  @@index([productId])
}

model Production {
  id         String   @id @default(cuid())
  tenantId   String
  siteId     String
  productId  String
  variantId  String?
  quantidade Int      @default(1)
  saleId     String? // se a produção foi disparada por uma venda
  data       DateTime @default(now())
  observacao String?
  createdAt  DateTime @default(now())

  site Site @relation(fields: [siteId], references: [id])

  @@index([tenantId])
  @@index([siteId])
  @@index([productId])
  @@index([saleId])
}

// ============================================================
// FASE 4 — VENDAS / CHECKOUT
// Dois sabores sobre a mesma base: PDV (operador) e self-service (totem/app).
// Finalizar a venda dispara a baixa de estoque (SAIDA / PRODUCAO) no site.
// ============================================================

model Sale {
  id             String     @id @default(cuid())
  tenantId       String
  siteId         String
  origem         SaleOrigin @default(PDV)
  status         SaleStatus @default(ABERTA)
  cashSessionId  String? // só PDV
  operatorUserId String? // só PDV
  customerId     String? // cliente identificado (fidelização) — opcional
  totemDeviceId  String? // terminal de autoatendimento que originou a venda

  subtotal Decimal @default(0) @db.Decimal(12, 2)
  desconto Decimal @default(0) @db.Decimal(12, 2)
  total    Decimal @default(0) @db.Decimal(12, 2)

  maiorIdadeConfirmada Boolean @default(false) // +18 confirmado no fechamento

  // "CPF na nota" digitado no fechamento — vai ao dest da NFC-e sem criar um
  // Customer. O caso do balcão: o cliente quer CPF na nota, não quer cadastro.
  // Só dígitos. Cliente identificado (customerId) tem prioridade.
  cpfNota String?

  createdAt DateTime  @default(now())
  paidAt    DateTime?

  site        Site             @relation(fields: [siteId], references: [id])
  cashSession CashSession?     @relation(fields: [cashSessionId], references: [id])
  customer    Customer?        @relation(fields: [customerId], references: [id], onDelete: SetNull)
  totemDevice TotemDevice?     @relation(fields: [totemDeviceId], references: [id], onDelete: SetNull)
  items       SaleItem[]
  payments    Payment[]
  fiscalDocs  FiscalDocument[]

  @@index([tenantId])
  @@index([siteId])
  @@index([cashSessionId])
  @@index([customerId])
  @@index([totemDeviceId])
  @@index([status])
  @@index([createdAt])
}

// Terminal físico de autoatendimento. Registrado pelo quiosque no primeiro
// uso (id fica no localStorage do aparelho); heartbeat mantém lastSeenAt —
// "ativo" = visto nos últimos 2 minutos (fila do PDV).
model TotemDevice {
  id         String   @id @default(cuid())
  tenantId   String
  siteId     String
  nome       String // "Terminal 01"
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())

  site  Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)
  sales Sale[]

  @@index([tenantId])
  @@index([siteId])
}

model SaleItem {
  id            String  @id @default(cuid())
  tenantId      String
  saleId        String
  productId     String
  variantId     String?
  quantidade    Decimal @db.Decimal(12, 3)
  precoUnitario Decimal @db.Decimal(10, 2)
  desconto      Decimal @default(0) @db.Decimal(10, 2)
  total         Decimal @db.Decimal(12, 2)

  // PERSONALIZADO: componentes escolhidos no PDV — guiam a baixa de estoque.
  selectedComponentIds String[] @default([])

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([saleId])
  @@index([productId])
}

model Payment {
  id         String        @id @default(cuid())
  tenantId   String
  saleId     String
  metodo     PaymentMethod
  status     PaymentStatus @default(CONFIRMADO)
  valor      Decimal       @db.Decimal(12, 2)
  troco      Decimal?      @db.Decimal(10, 2) // dinheiro
  gateway    String? // slug do provedor (MERCADO_PAGO, SIMULADO) — null = manual
  externalId String? // id da cobrança/intenção no provedor (webhook faz lookup)

  // PIX dinâmico — preenchidos ao criar a cobrança no provedor
  pixCopiaECola String?   @db.Text
  pixQrCode     String?   @db.Text // imagem base64 (png) retornada pelo provedor
  expiraEm      DateTime?

  // Cartão integrado — terminal que recebeu a intenção de pagamento
  terminalId String?

  // Cartão — devolvidos pelo PSP na APROVAÇÃO, nunca digitados pelo operador.
  // Bandeira é dado do adquirente: perguntar ao caixa gera erro e atraso, e o
  // que ele digita não vale nada perante a SEFAZ. Alimentam o grupo `card` da
  // NFC-e (YA04a) e a conciliação com o extrato do PSP.
  bandeira       String? // normalizada: VISA, MASTERCARD, ELO, AMEX, HIPERCARD, …
  parcelas       Int?
  nsu            String? // número sequencial único do adquirente
  autorizacao    String? // authorization_code → cAut da NFC-e
  adquirenteCnpj String? // credenciadora → card.CNPJ da NFC-e
  // Id da TRANSAÇÃO no PSP. Diferente de externalId (que é a intenção/pedido
  // enviada à maquininha) — o estorno e a conciliação precisam deste.
  pspPaymentId String?

  createdAt DateTime @default(now())

  sale     Sale             @relation(fields: [saleId], references: [id], onDelete: Cascade)
  terminal PaymentTerminal? @relation(fields: [terminalId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([saleId])
  @@index([status])
  @@index([externalId])
}

// ── Pagamento integrado (Payment Service) ──────────────────
// Config por tenant: qual provedor processa PIX dinâmico e maquininha.
// Credenciais só no servidor — nunca expostas ao browser.
model PaymentProviderConfig {
  id       String              @id @default(cuid())
  tenantId String              @unique
  provider PaymentProviderKind
  ativo    Boolean             @default(true)

  accessToken   String // token privado do PSP (Mercado Pago: Access Token de produção; Stone: sk_ Pagar.me)
  webhookSecret String? // assinatura de webhook (Mercado Pago: secret do painel; Stone: Basic Auth "usuario:senha")
  partnerRef    String? // Stone Connect: ServiceRefererName (código do Programa de Parcerias) — exigido p/ cartão no POS
  ambiente      PaymentAmbiente @default(PRODUCAO) // PagBank: produção x sandbox — hosts de API diferentes

  pixAutomatico   Boolean @default(true) // PIX gera QR dinâmico e confirma sozinho
  cartaoIntegrado Boolean @default(false) // envia valor à maquininha via API

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// Maquininha vinculada a um site/caixa (Mercado Pago Point: device_id).
model PaymentTerminal {
  id         String              @id @default(cuid())
  tenantId   String
  siteId     String
  nome       String // "Point Caixa 01"
  provider   PaymentProviderKind
  externalId String // device_id no provedor
  ativo      Boolean             @default(true)
  createdAt  DateTime            @default(now())

  site     Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  payments Payment[]

  @@unique([tenantId, externalId])
  @@index([tenantId])
  @@index([siteId])
}

model CashSession {
  id              String            @id @default(cuid())
  tenantId        String
  siteId          String
  operatorUserId  String
  status          CashSessionStatus @default(ABERTA)
  valorAbertura   Decimal           @db.Decimal(12, 2)
  valorFechamento Decimal?          @db.Decimal(12, 2) // contado no fechamento
  abertaEm        DateTime          @default(now())
  fechadaEm       DateTime?

  site      Site           @relation(fields: [siteId], references: [id])
  sales     Sale[]
  movements CashMovement[]

  @@index([tenantId])
  @@index([siteId])
  @@index([status])
}

model CashMovement {
  id            String           @id @default(cuid())
  tenantId      String
  cashSessionId String
  tipo          CashMovementType
  valor         Decimal          @db.Decimal(12, 2)
  motivo        String?
  createdAt     DateTime         @default(now())

  cashSession CashSession @relation(fields: [cashSessionId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([cashSessionId])
}

// Métodos de pagamento aceitos por site (defaults vêm do preset de atendimento)
model SitePaymentMethod {
  id       String        @id @default(cuid())
  tenantId String
  siteId   String
  metodo   PaymentMethod
  ativo    Boolean       @default(true)

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, metodo])
  @@index([tenantId])
}

// ============================================================
// CRM / FIDELIZAÇÃO
// Cadastro leve do consumidor final para fidelização. Métricas (total gasto,
// ticket, visitas, produtos favoritos) NÃO ficam aqui — derivam de Sale/SaleItem
// via customerId, computadas ao vivo. `pontos` é o único saldo materializado.
// ============================================================

model Customer {
  id             String    @id @default(cuid())
  tenantId       String
  nome           String
  cpf            String? // só dígitos
  dataNascimento DateTime? @db.Date
  sexo           Sexo?
  whatsapp       String? // só dígitos (DDD + número)
  email          String?
  pontos         Int       @default(0)
  ativo          Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Fiscal — exigido só na NF-e (modelo 55). Na NFC-e o CPF basta, e mesmo
  // ele é opcional ("consumidor não identificado").
  cnpj            String? // só dígitos — cliente PJ
  razaoSocial     String?
  ie              String?
  indicadorIE     IndicadorIE?
  cep             String?
  logradouro      String?
  numero          String?
  complemento     String?
  bairro          String?
  municipio       String?
  codigoMunicipio String? // IBGE (7 dígitos) — a NF-e pede o código, não o nome
  uf              String?

  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sales              Sale[]
  coupons            CouponSend[]
  comodatoLoans      ComodatoLoan[]
  containerMovements ContainerMovement[]
  fiscalDocuments    FiscalDocument[]

  @@unique([tenantId, cpf])
  @@index([tenantId])
  @@index([tenantId, nome])
}

// Registro de cupom enviado (risco/aniversário/manual). Serve de trava para não
// reenviar o mesmo tipo em janela curta e de histórico do disparo (WhatsApp).
model CouponSend {
  id         String       @id @default(cuid())
  tenantId   String
  customerId String
  motivo     CouponReason
  automatico Boolean      @default(false)
  mensagem   String?
  createdAt  DateTime     @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([customerId])
  @@index([createdAt])
}

// ============================================================
// COMODATO
// Ativos emprestados a clientes. Dois sabores:
// (1) ComodatoAsset: equipamento serializado (chopeira, freezer, cilindro) com
//     ciclo empréstimo→devolução via ComodatoLoan (aberto = devolvidoEm null).
// (2) ContainerType + ContainerMovement: vasilhames retornáveis por quantidade
//     (cascos/barris) — razão ASSINADO por cliente; saldo = Σ quantidade.
// ============================================================

model ComodatoAsset {
  id            String              @id @default(cuid())
  tenantId      String
  nome          String // ex.: "Chopeira 2 vias"
  identificacao String // serial / nº de patrimônio
  status        ComodatoAssetStatus @default(DISPONIVEL)
  valorEstimado Decimal?            @db.Decimal(10, 2) // valor de reposição
  observacao    String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  tenant Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  loans  ComodatoLoan[]

  @@unique([tenantId, identificacao])
  @@index([tenantId])
  @@index([tenantId, status])
}

// Empréstimo de UM equipamento a UM cliente. Aberto = devolvidoEm null.
// Invariante (garantida nas actions): no máximo 1 loan aberto por asset.
model ComodatoLoan {
  id                String    @id @default(cuid())
  tenantId          String
  assetId           String
  customerId        String
  emprestadoEm      DateTime  @default(now())
  previsaoDevolucao DateTime? @db.Date
  devolvidoEm       DateTime?
  condicaoSaida     String? // estado do equipamento na entrega
  condicaoRetorno   String? // estado na devolução
  observacao        String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  asset    ComodatoAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  customer Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([tenantId, devolvidoEm])
  @@index([assetId])
  @@index([customerId])
}

// Tipo de vasilhame retornável controlado por quantidade (casco, barril 30L…).
model ContainerType {
  id            String   @id @default(cuid())
  tenantId      String
  nome          String
  valorUnitario Decimal? @db.Decimal(10, 2) // valor de reposição unitário
  ativo         Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant    Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  movements ContainerMovement[]

  @@unique([tenantId, nome])
  @@index([tenantId])
}

// Razão assinado: quantidade guardada JÁ com sinal (ENTREGA > 0, DEVOLUCAO < 0,
// AJUSTE +/-). Saldo do cliente = SUM(quantidade) por (customer × type).
model ContainerMovement {
  id              String                @id @default(cuid())
  tenantId        String
  containerTypeId String
  customerId      String
  tipo            ContainerMovementType
  quantidade      Int // assinada
  observacao      String?
  createdAt       DateTime              @default(now())

  containerType ContainerType @relation(fields: [containerTypeId], references: [id], onDelete: Restrict)
  customer      Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([tenantId, customerId])
  @@index([containerTypeId])
  @@index([customerId])
}

// ============================================================
// ANALYTICS (Fase 7)
// StockSnapshot: foto diária do saldo/valor por (produto × site). Capturado por
// job diário (idempotente por dia). Necessário PROSPECTIVAMENTE — giro e valor
// histórico de estoque não se reconstroem barato a partir do razão.
// productId/siteId são escalares (alto volume; alinhado a StockMovement).
// ============================================================

model StockSnapshot {
  id        String   @id @default(cuid())
  tenantId  String
  siteId    String
  productId String
  data      DateTime @db.Date

  saldoFechado Decimal  @db.Decimal(12, 3)
  saldoAberto  Decimal  @db.Decimal(12, 3)
  custoMedio   Decimal? @db.Decimal(10, 2)
  valorEstoque Decimal? @db.Decimal(14, 2) // (fechado + aberto convertido) × custoMedio

  createdAt DateTime @default(now())

  @@unique([siteId, productId, data])
  @@index([tenantId])
  @@index([siteId, data])
  @@index([data])
}

// ── Feedback dos insights do dashboard (/inicio) ────────────────
// Alimenta a repriorização por aprendizado: regras muito ignoradas descem
// de prioridade nos cards seguintes. `insightId` é a CHAVE DA REGRA (ex.:
// "ticket", "produto-crescimento"), não o id de uma instância — várias
// linhas por regra ao longo do tempo formam o histórico.

enum InsightFeedbackAcao {
  IGNORADO
  CLICADO
}

model InsightFeedback {
  id        String              @id @default(cuid())
  tenantId  String
  insightId String
  acao      InsightFeedbackAcao
  createdAt DateTime            @default(now())

  @@index([tenantId, insightId])
  @@index([tenantId, createdAt])
}

// Personalização do Centro de Operações (/inicio) — por usuário, por tenant.
// `hidden` = ids de widget ocultados; `ordem` = ids na ordem escolhida (widgets
// fora da lista entram no fim, na ordem default — ver inicio/_widgets.ts).
model DashboardWidgetPref {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  hidden    String[] @default([])
  ordem     String[] @default([])
  updatedAt DateTime @updatedAt

  @@unique([tenantId, userId])
}

// ============================================================
// FISCAL — emissão de documentos eletrônicos e entrada de XML.
//
// PRINCÍPIO: o NoHub não apura imposto nem gera SPED. Ele monta o documento,
// delega assinatura/transmissão ao provedor (FiscalProvider) e guarda o
// resultado. A legislação fica encapsulada no provedor.
//
// EMISSÃO É ASSÍNCRONA. A venda NUNCA espera a SEFAZ: fecha o caixa, cria o
// FiscalDocument em PENDENTE e um worker transmite. SEFAZ fora do ar não pode
// parar a loja — é também o que viabiliza contingência.
//
// O certificado A1 NÃO mora aqui: sobe uma vez para o provedor, que o guarda
// por CNPJ. Guardamos só o id opaco, o titular e a validade (para avisar do
// vencimento). Sem chave privada no nosso banco.
// ============================================================

enum FiscalProviderKind {
  NUVEM_FISCAL
  PLUGNOTAS
  FOCUS
  TECNOSPEED
  SIMULADO // desenvolvimento/demonstração, sem certificado nem SEFAZ
}

enum FiscalAmbiente {
  PRODUCAO // tpAmb 1
  HOMOLOGACAO // tpAmb 2
}

enum FiscalModelo {
  NFCE // modelo 65 — venda ao consumidor no PDV
  NFE // modelo 55 — pedido faturado, entrada, devolução
}

enum FiscalDirecao {
  SAIDA
  ENTRADA
}

enum FiscalStatus {
  PENDENTE // na fila, ainda não transmitido
  PROCESSANDO // enviado ao provedor, aguardando retorno da SEFAZ
  AUTORIZADO
  REJEITADO // erro de validação — corrigir e reemitir
  DENEGADO // SEFAZ negou por irregularidade do destinatário (não reemitir)
  CANCELADO
  CONTINGENCIA // emitido offline, pendente de transmissão
  INUTILIZADO // faixa de numeração queimada
}

enum FiscalEventoTipo {
  EMISSAO
  CANCELAMENTO
  CARTA_CORRECAO
  INUTILIZACAO
  REJEICAO
  CONTINGENCIA
  MANIFESTACAO
}

enum FiscalInboundStatus {
  PENDENTE // XML importado, itens ainda não relacionados a produtos
  CONCILIADO // todos os itens têm produto — pronto para gerar entrada
  RECEBIDO // entrada gerada (Purchase criada, estoque movimentado)
  DESCARTADO // nota que não vira entrada (já lançada, devolvida, erro)
}

enum ManifestacaoTipo {
  CIENCIA
  CONFIRMACAO
  DESCONHECIMENTO
  NAO_REALIZADA
}

/**
 * CRT do emitente. Define se o item sai com CSOSN (Simples) ou CST (Normal).
 */
enum RegimeTributario {
  SIMPLES_NACIONAL // CRT 1
  SIMPLES_EXCESSO // CRT 2
  REGIME_NORMAL // CRT 3
}

/**
 * indIEDest do destinatário.
 */
enum IndicadorIE {
  CONTRIBUINTE // 1
  ISENTO // 2
  NAO_CONTRIBUINTE // 9
}

// Credenciais do provedor fiscal — uma por tenant. O certificado é por CNPJ
// (ver FiscalEmitente); aqui fica só o acesso à API e o comportamento padrão.
model FiscalConfig {
  id       String             @id @default(cuid())
  tenantId String             @unique
  provider FiscalProviderKind @default(SIMULADO)
  ambiente FiscalAmbiente     @default(HOMOLOGACAO)
  ativo    Boolean            @default(false)

  apiToken      String? // token privado do provedor — nunca vai ao browser
  webhookSecret String? // valida o callback de autorização

  // Emitir NFC-e automaticamente ao confirmar o pagamento no PDV. Desligado
  // por padrão: muitos mercadinhos operam sem obrigação de emissão.
  emissaoAutomaticaNfce Boolean @default(false)

  // Minutos após a autorização em que a SEFAZ ainda aceita cancelamento de
  // NFC-e. Varia por UF (30 na maioria) — a UI usa isso para não oferecer um
  // botão que vai falhar.
  prazoCancelamentoMin Int @default(30)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// Estabelecimento emitente — um por loja (Site). Multiempresa sai de graça:
// cada loja pode ter CNPJ, IE e certificado próprios. Loja sem emitente
// simplesmente não emite.
model FiscalEmitente {
  id       String @id @default(cuid())
  tenantId String
  siteId   String @unique

  cnpj         String // só dígitos
  razaoSocial  String
  nomeFantasia String?
  ie           String
  im           String? // inscrição municipal (serviços)
  cnae         String?
  regime       RegimeTributario @default(SIMPLES_NACIONAL)

  cep             String
  logradouro      String
  numero          String
  complemento     String?
  bairro          String
  municipio       String
  codigoMunicipio String // IBGE (7 dígitos)
  uf              String
  telefone        String?

  // Certificado A1 — armazenado NO PROVEDOR. Aqui só o rastro.
  certificadoId       String? // id opaco devolvido pelo provedor
  certificadoTitular  String? // CN do certificado, para conferência visual
  certificadoValidade DateTime?

  // NFC-e (modelo 65): CSC/token vêm do portal da SEFAZ da UF.
  cscId String? // idToken (identificador do CSC)
  csc   String? // código de segurança do contribuinte

  naturezaOperacaoPadrao String @default("Venda de mercadoria")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  site   Site   @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([tenantId, cnpj])
  @@index([tenantId])
}

// Contador de numeração por (loja × modelo × série). O próximo número sai de
// um UPDATE … RETURNING atômico — nunca de max(numero)+1, que gera duplicidade
// sob concorrência e derruba a nota na SEFAZ.
model FiscalSerie {
  id            String       @id @default(cuid())
  tenantId      String
  siteId        String
  modelo        FiscalModelo
  serie         Int
  proximoNumero Int          @default(1)
  ativa         Boolean      @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  site Site @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, modelo, serie])
  @@index([tenantId])
}

// Documento fiscal que nós emitimos. O XML/PDF fica em blob storage — aqui só
// a URL, a chave de 44 dígitos e o protocolo.
model FiscalDocument {
  id       String         @id @default(cuid())
  tenantId String
  siteId   String
  modelo   FiscalModelo
  direcao  FiscalDirecao  @default(SAIDA)
  status   FiscalStatus   @default(PENDENTE)
  ambiente FiscalAmbiente

  serie  Int
  numero Int

  chave      String? // 44 dígitos — só existe após montar o documento
  protocolo  String? // nProt da autorização
  externalId String? // id do documento no provedor

  // Chave de idempotência. Retry de rede não pode emitir a mesma nota duas
  // vezes — a unicidade por tenant é a trava.
  idempotencyKey String

  naturezaOperacao String
  dataEmissao      DateTime  @default(now())
  dataAutorizacao  DateTime?

  saleId     String?
  purchaseId String?
  customerId String?
  supplierId String?

  // Snapshot do destinatário no momento da emissão — o cadastro muda, a nota
  // não. Sem isso a segunda via mente.
  destNome      String?
  destDocumento String? // CPF/CNPJ, só dígitos

  valorProdutos Decimal @default(0) @db.Decimal(12, 2)
  valorDesconto Decimal @default(0) @db.Decimal(12, 2)
  valorTotal    Decimal @default(0) @db.Decimal(12, 2)

  codigoRejeicao String? // cStat da SEFAZ (ex.: "539")
  motivoRejeicao String? // xMotivo legível — vai direto para a tela
  tentativas     Int     @default(0)
  contingencia   Boolean @default(false)

  xmlUrl      String? // XML autorizado (blob privado)
  pdfUrl      String? // DANFE / DANFE-NFC-e
  qrCodeUrl   String? // NFC-e: URL do QR Code impressa no cupom
  urlConsulta String? // consulta pública na SEFAZ

  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  site     Site                 @relation(fields: [siteId], references: [id])
  sale     Sale?                @relation(fields: [saleId], references: [id], onDelete: SetNull)
  purchase Purchase?            @relation(fields: [purchaseId], references: [id], onDelete: SetNull)
  customer Customer?            @relation(fields: [customerId], references: [id], onDelete: SetNull)
  supplier Supplier?            @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  items    FiscalDocumentItem[]
  eventos  FiscalEvent[]

  @@unique([tenantId, idempotencyKey])
  @@unique([tenantId, chave])
  @@unique([siteId, modelo, serie, numero])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([siteId, dataEmissao])
  @@index([saleId])
  @@index([customerId])
  @@index([supplierId])
}

// Item da nota — SNAPSHOT completo. Nunca leia o produto para reimprimir uma
// nota: preço, NCM e alíquota do cadastro mudam; os da nota são imutáveis.
// productId é escalar (alto volume, igual a StockMovement).
model FiscalDocumentItem {
  id         String  @id @default(cuid())
  tenantId   String
  documentId String
  ordem      Int // nItem no XML (1-based)
  productId  String?

  codigo    String // cProd
  descricao String
  gtin      String? // cEAN
  ncm       String
  cest      String?
  cfop      String
  origem    String  @default("0")
  cst       String?
  csosn     String?

  unidade       String
  quantidade    Decimal @db.Decimal(12, 4)
  valorUnitario Decimal @db.Decimal(12, 4)
  valorTotal    Decimal @db.Decimal(12, 2)
  valorDesconto Decimal @default(0) @db.Decimal(12, 2)

  baseIcms     Decimal? @db.Decimal(12, 2)
  aliquotaIcms Decimal? @db.Decimal(5, 2)
  valorIcms    Decimal? @db.Decimal(12, 2)
  valorIcmsSt  Decimal? @db.Decimal(12, 2)
  valorPis     Decimal? @db.Decimal(12, 2)
  valorCofins  Decimal? @db.Decimal(12, 2)

  document FiscalDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, ordem])
  @@index([tenantId])
  @@index([documentId])
  @@index([productId])
}

// Trilha append-only: emissão, cancelamento, CC-e, inutilização, rejeição,
// contingência, manifestação. É histórico fiscal E auditoria — nunca atualize
// nem apague uma linha daqui.
model FiscalEvent {
  id         String           @id @default(cuid())
  tenantId   String
  documentId String? // inutilização não tem documento
  tipo       FiscalEventoTipo

  sequencia Int? // nSeqEvento (CC-e permite até 20)
  motivo    String? // justificativa (mín. 15 caracteres na SEFAZ)
  protocolo String?
  codigo    String? // cStat do retorno
  mensagem  String? // xMotivo

  // Inutilização de faixa (sem documento associado).
  serie         Int?
  numeroInicial Int?
  numeroFinal   Int?

  payload   Json? // retorno bruto do provedor — ouro no suporte
  userId    String?
  createdAt DateTime @default(now())

  document FiscalDocument? @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([documentId])
}

// Nota de FORNECEDOR (XML de entrada). Caminho:
// XML → relacionar itens a produtos → gerar Purchase → estoque + custo médio.
model FiscalInbound {
  id       String              @id @default(cuid())
  tenantId String
  siteId   String // loja onde a mercadoria entra
  status   FiscalInboundStatus @default(PENDENTE)

  chave       String // 44 dígitos — trava contra importar a mesma nota duas vezes
  modelo      String   @default("55")
  numero      Int
  serie       Int
  dataEmissao DateTime
  valorTotal  Decimal  @db.Decimal(12, 2)

  // Emitente do XML, guardado cru: o Supplier pode ainda não existir no
  // cadastro, e a importação não pode travar por causa disso.
  emitCnpj        String
  emitRazaoSocial String
  emitUf          String?
  supplierId      String?

  purchaseOrderId String? // pedido de compra conciliado
  purchaseId      String? @unique // entrada gerada

  manifestacao  ManifestacaoTipo?
  manifestadoEm DateTime?

  xmlUrl       String?
  observacao   String?
  importadoPor String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  site          Site                @relation(fields: [siteId], references: [id])
  supplier      Supplier?           @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  purchaseOrder PurchaseOrder?      @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  purchase      Purchase?           @relation(fields: [purchaseId], references: [id], onDelete: SetNull)
  items         FiscalInboundItem[]

  @@unique([tenantId, chave])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([siteId])
  @@index([supplierId])
}

// Item do XML do fornecedor + o produto ao qual foi relacionado. Enquanto
// houver item com productId null a nota fica PENDENTE.
model FiscalInboundItem {
  id        String @id @default(cuid())
  tenantId  String
  inboundId String
  ordem     Int

  // Como veio no XML.
  codigoFornecedor String // cProd
  gtin             String? // cEAN
  descricao        String
  ncm              String?
  cfop             String?
  unidade          String
  quantidade       Decimal @db.Decimal(12, 4)
  valorUnitario    Decimal @db.Decimal(12, 4)
  valorTotal       Decimal @db.Decimal(12, 2)
  valorDesconto    Decimal @default(0) @db.Decimal(12, 2)
  valorIcmsSt      Decimal @default(0) @db.Decimal(12, 2)
  valorIpi         Decimal @default(0) @db.Decimal(12, 2)
  valorFrete       Decimal @default(0) @db.Decimal(12, 2)

  // Resolução no nosso catálogo.
  productId      String?
  packagingId    String? // fornecedor manda caixa, estoque conta unidade
  // Unidades do nosso estoque por unidade do XML (caixa com 12 → 12).
  fatorConversao Decimal @default(1) @db.Decimal(12, 4)
  bonificacao    Boolean @default(false) // CFOP de bonificação: entra sem custo

  inbound FiscalInbound @relation(fields: [inboundId], references: [id], onDelete: Cascade)

  @@unique([inboundId, ordem])
  @@index([tenantId])
  @@index([inboundId])
  @@index([productId])
}

// De-para persistido fornecedor↔catálogo. Escrito quando o operador relaciona
// um item na primeira nota; da segunda em diante a importação resolve sozinha.
// É o que faz a entrada por XML valer a pena no dia a dia.
model SupplierItemMap {
  id               String  @id @default(cuid())
  tenantId         String
  supplierId       String
  codigoFornecedor String // cProd do XML
  gtin             String?
  productId        String
  packagingId      String?
  fatorConversao   Decimal @default(1) @db.Decimal(12, 4)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@unique([supplierId, codigoFornecedor])
  @@index([tenantId])
  @@index([productId])
}
